<Window x:Class="DotNetDz2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DotNetDz2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border BorderThickness="1" Grid.Column="0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="mainListBox" Grid.Row="0" SelectionChanged="OnSelectionChanged" Margin="10">
                 <ListBox.ItemTemplate>
                 <DataTemplate>
                 <Border Padding="8" Margin="2">
                  <StackPanel>
                 <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                 <TextBlock Text="{Binding Company}" FontSize="12" Margin="4" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Price}" FontSize="12" Margin="4" VerticalAlignment="Center"/>
               </StackPanel>
               </Border>
               </DataTemplate>
               </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10">
                    <Button Content="+" FontSize="24" Width="50" Height="50" Click="AddButton_Click" Margin="10"/>
                    <Button Content="-" FontSize="24" Width="50" Height="50" Click="Remove_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border BorderThickness="1" Grid.Column="1">
            <StackPanel Margin="10">
                <Label Content="Выбранный элемент" FontWeight="Bold" FontSize="14" Margin="5"/>
                <Label Content="Модель:" FontSize="13" Margin="15"/>
                <TextBox x:Name="modelTextBox" Margin="0,0,0,15" Height="25"/>
                <Label Content="Производитель:" FontSize="13" Margin="5"/>
                <TextBox x:Name="companyTextBox" Margin="0,0,0,15" Height="25"/>
                <Label Content="Цена:" FontSize="13" Margin="0,0,0,15"/>
                <TextBox x:Name="priceTextBox" Margin="0,0,0,15" Height="25"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
